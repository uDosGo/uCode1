10 REM Maths Fun - Numbers and Arithmetic
20 MODE 7
30 COLOUR 3
40 PRINT TAB(0,2);"Maths Fun!"
50 PRINT TAB(0,4);"Enter two numbers:"
60 INPUT "Number 1: ";A
70 INPUT "Number 2: ";B
80 CLS
90 PRINT "A = ";A
100 PRINT "B = ";B
110 PRINT ""
120 PRINT "A + B = ";A + B
130 PRINT "A - B = ";A - B
140 PRINT "A * B = ";A * B
150 IF B <> 0 THEN PRINT "A / B = ";A / B
160 PRINT "A MOD B = ";A MOD B
170 PRINT "A DIV B = ";A DIV B
180 PRINT ""
190 PRINT "SQR(A) = ";SQR(A)
200 PRINT "RND = ";RND(100)
210 END
